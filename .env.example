# Render Deployment Environment Variables
# Copy to .env and fill values

# Django Secret Key (generate new for prod: https://djecrety.ir/)
SECRET_KEY=your-secret-key-here

# Debug (false for production)
DEBUG=false

# Allowed Hosts
ALLOWED_HOSTS=yourapp.onrender.com,.onrender.com

# Render PostgreSQL (from Render dashboard)
DATABASE_URL=postgres://user:pass@host:port/db

# Alternative manual Postgres vars (local docker-compose)
# POSTGRES_DB=authdb
# POSTGRES_USER=authuser
# POSTGRES_PASSWORD=authpass

# App URL for QR verification
PUBLIC_BASE_URL=https://yourapp.onrender.com
