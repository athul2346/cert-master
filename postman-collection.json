{
    "info": {
        "_postman_id": "company-documents-api-final",
        "name": "Company Documents API - Complete",
        "description": "Complete API collection for certificate management and rendering",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000/api",
            "type": "string"
        },
        {
            "key": "authToken",
            "value": "",
            "type": "string"
        }
    ],
    "auth": {
        "type": "bearer",
