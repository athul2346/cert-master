        {
            "name": "Document JSON Partial Updates",
            "item": [
                {
                    "name": "Patch Document JSON",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/documents/1/update-json/",
                            "host": ["{{baseUrl}}"],
                            "path": ["documents", "1", "update-json", ""]
                        },
                        "description": "Partially update document_json: add new keys, update existing keys, and delete old keys atomically",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"to_add\": {\n        \"new_certificate_number\": \"CERT-2024-001\",\n        \"issuing_authority\": \"National Certification Board\",\n        \"version\": \"2.0\"\n    },\n    \"to_update\": {\n        \"holder_name\": \"John Smith Updated\"\n    },\n    \"to_delete\": [\"temporary_field\", \"legacy_field\"]\n}"
                        }
                    }
