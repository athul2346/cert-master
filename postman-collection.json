		{
			"name": "Real-World Workflows",
			"item": [
				{
					"name": "Certificate Lifecycle with JSON Updates",
					"item": [
						{
							"name": "1. Create Document",
							"request": {
								"method": "POST",
								"header": [{"key": "Content-Type", "value": "application/json"}],
								"url": {
									"raw": "{{baseUrl}}/documents/",
									"host": ["{{baseUrl}}"],
									"path": ["documents", ""]
								},
								"body": {
									"mode": "raw",
									"raw": "{\n    \"document_type\": \"CERTIFICATE\",\n    \"template\": \"certificate_template\",\n    \"recipient\": \"John Doe\",\n    \"document_json\": {\n        \"certificate_number\": \"CERT-2024-001\",\n        \"holder_name\": \"John Doe\",\n        \"initial_status\": \"PENDING_VERIFICATION\"\n    },\n    \"issued_date\": \"2024-01-01\",\n    \"expiry_date\": \"2025-01-01\"\n}"
								}
							}
						},
						{
							"name": "2. Add Verification Data",
							"request": {
								"method": "PATCH",
								"header": [{"key": "Content-Type", "value": "application/json"}],
								"url": {
									"raw": "{{baseUrl}}/documents/CERTIFICATE/John%20Doe/update-json/",
									"host": ["{{baseUrl}}"],
									"path": ["documents", "CERTIFICATE", "John%20Doe", "update-json", ""]
								},
								"body": {
									"mode": "raw",
									"raw": "{\n    \"to_add\": {\n        \"verification\": {\n            \"verified_by\": \"admin@company.com\",\n            \"verified_at\": \"2024-01-15T10:00:00Z\",\n            \"verification_method\": \"automated\",\n            \"score\": 98.5\n        }\n    },\n    \"to_update\": {\n        \"initial_status\": \"VERIFIED\"\n    },\n    \"to_delete\": [\"initial_status\"]\n}"
								}
							}
						},
						{
							"name": "3. Update Expiry Date",
							"request": {
								"method": "PATCH",
								"header": [{"key": "Content-Type", "value": "application/json"}],
								"url": {
									"raw": "{{baseUrl}}/documents/CERTIFICATE/John%20Doe/update-json/",
									"host": ["{{baseUrl}}"],
									"path": ["documents", "CERTIFICATE", "John%20Doe", "update-json", ""]
								},
								"body": {
									"mode": "raw",
									"raw": "{\n    \"to_add\": {\n        \"renewal_info\": {\n            \"original_expiry\": \"2025-01-01\",\n            \"renewed_at\": \"2024-12-15\"\n        }\n    },\n    \"to_update\": {\n        \"certificate_number\": \"CERT-2024-001-RENEWED\",\n        \"expiry_date\": \"2026-01-01\"\n    }\n}"
								}
							}
						},
						{
							"name": "4. Archive Document",
							"request": {
								"method": "PATCH",
								"header": [{"key": "Content-Type", "value": "application/json"}],
								"url": {
									"raw": "{{baseUrl}}/documents/CERTIFICATE/John%20Doe/update-json/",
									"host": ["{{baseUrl}}"],
									"path": ["documents", "CERTIFICATE", "John%20Doe", "update-json", ""]
								},
								"body": {
									"mode": "raw",
									"raw": "{\n    \"to_add\": {\n        \"archive_info\": {\n            \"archived_at\": \"2026-01-02\",\n            \"reason\": \"certificate_expired\",\n            \"preserved_for_years\": 7\n        }\n    },\n    \"to_update\": {\n        \"status\": \"ARCHIVED\"\n    },\n    \"to_delete\": [\n        \"verification\",\n        \"renewal_info\"\n    ]\n}"
								}
							}
						}
					]
				},
