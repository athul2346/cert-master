						},
						"body": {
							"mode": "raw",
							"raw": "{\n    \"to_delete\": [\n        \"temporary_data\",\n        \"debug_info\",\n        \"old_verification_id\"\n    ]\n}"
						}
					}
				},
				{
					"name": "Complex Update - All Operations",
					"request": {
						"method": "PATCH",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {
							"raw": "{{baseUrl}}/documents/CERTIFICATE/John%20Doe/update-json/",
							"host": ["{{baseUrl}}"],
							"path": ["documents", "CERTIFICATE", "John%20Doe", "update-json", ""]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n    \"to_add\": {\n        \"renewal_history\": [\n            {\"date\": \"2024-01-01\", \"action\": \"renewed\"},\n            {\"date\": \"2025-01-01\", \"action\": \"renewed_again\"}\n        ],\n        \"digital_signature\": {\n            \"algorithm\": \"RSA-2048\",\n            \"signed_at\": \"2024-01-15T10:00:00Z\"\n        }\n    },\n    \"to_update\": {\n        \"status\": \"ACTIVE\",\n        \"last_verified\": \"2024-01-15\",\n        \"expiry_date\": \"2026-01-01\"\n    },\n    \"to_delete\": [\n        \"pending_renewal_flag\",\n        \"temp_verification_id\"\n    ]\n}"
						}
					}
				}
			]
		},
