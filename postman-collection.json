                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/login/",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "login", ""]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"your-password\"\n}"
                        }
                    }
                },
                {
                    "name": "Signup",
                    "request": {
                        "method": "POST",
                        "header": [
