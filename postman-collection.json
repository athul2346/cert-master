						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {
							"raw": "{{baseUrl}}/documents/CERTIFICATE/John%20Doe/update-json/",
							"host": ["{{baseUrl}}"],
							"path": ["documents", "CERTIFICATE", "John%20Doe", "update-json", ""]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n    \"to_add\": {\n        \"additional_info\": \"This is new data\",\n        \"tags\": [\"certified\", \"verified\", \"2024\"],\n        \"custom_fields\": {\n            \"field1\": \"value1\",\n            \"field2\": \"value2\"\n        }\n    }\n}"
						}
					}
				},
