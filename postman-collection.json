                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/signup/",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "signup", ""]
