                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"company@example.com\",\n    \"password\": \"secure-password123\",\n    \"organisation_name\": \"My Company\",\n    \"classification\": \"private\",\n    \"country\": \"USA\",\n    \"cin_number\": \"CIN123456789\"\n}"
                        }
                    }
                }
            ]
        },
