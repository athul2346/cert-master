	"item": [
		{
			"name": "Document JSON Partial Updates",
			"item": [
				{
					"name": "Patch Document JSON - Add, Update & Delete Keys",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/documents/CERTIFICATE/John%20Doe/update-json/",
							"host": ["{{baseUrl}}"],
							"path": ["documents", "CERTIFICATE", "John%20Doe", "update-json", ""]
						},
						"description": "Partially update document_json: add new keys, update existing keys, and delete old keys atomically",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"to_add\": {\n        \"new_certificate_number\": \"CERT-2024-001\",\n        \"issuing_authority\": \"National Certification Board\",\n        \"version\": \"2.0\",\n        \"metadata\": {\n            \"last_verified\": \"2024-01-15\",\n            \"verification_count\": 5\n        }\n    },\n    \"to_update\": {\n        \"existing_field\": \"Updated Value\",\n        \"certificate_holder\": \"John Smith Updated\"\n    },\n    \"to_delete\": [\n        \"temporary_field\",\n        \"legacy_field\",\n        \"old_reference\"\n    ]\n}"
						}
					},
					"response": [
						{
							"name": "Success",
							"originalRequest": {
								"method": "PATCH",
								"header": [{"key": "Content-Type", "value": "application/json"}],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"message\": \"Document JSON updated successfully\",\n    \"operations\": {\n        \"added\": [\"new_certificate_number\", \"issuing_authority\", \"version\", \"metadata\"],\n        \"updated\": [\"existing_field\", \"certificate_holder\"],\n        \"deleted\": [\"temporary_field\", \"legacy_field\", \"old_reference\"]\n    },\n    \"document_json\": {\n        \"existing_field\": \"Updated Value\",\n        \"certificate_holder\": \"John Smith Updated\",\n        \"new_certificate_number\": \"CERT-2024-001\",\n        \"issuing_authority\": \"National Certification Board\",\n        \"version\": \"2.0\",\n        \"metadata\": {\n            \"last_verified\": \"2024-01-15\",\n            \"verification_count\": 5\n        }\n    }\n}"
								}
							},
							"_postman_previewlanguage": "json"
						}
					]
				},
				{
					"name": "Add New Keys Only",
					"request": {
